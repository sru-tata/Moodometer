{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@apps/*": ["apps/*"],
      "@components/*": ["components/*"],
      "@styles/*": ["styles/*"],
      "@assets/*": ["assets/*"],
      "@hooks/*": ["hooks/*"],
      "@context/*": ["context/*"],
      "@pages/*": ["pages/*"],
      "@utils/*": ["utils/*"],
      "@routes/*": ["routes/*"],
      "@common/*": ["components/common/*"],
	  "@services/*":["services/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}